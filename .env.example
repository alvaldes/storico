# ── Storico Environment Variables ──────────────────────────────────
#
# Copy this file to `.env` (same directory) and fill in the values.
# THIS IS THE SINGLE SOURCE OF TRUTH — both backend/ and frontend/ read
# from this file via symlinks (backend/.env -> ../.env, frontend/.env -> ../.env).
#
# Backend vars use prefix STORICO_ (pydantic-settings requirement).
# Frontend / Auth.js vars do NOT use the prefix.

## ── Backend (FastAPI — prefix STORICO_) ──────────────────────────

## PostgreSQL — uses asyncpg driver for async support.
## Local dev:     postgresql+asyncpg://storico:storico@localhost:5432/storico
## Neon:          postgresql+asyncpg://user:password@ep-xxx.aws.neon.tech/neondb?sslmode=require
STORICO_DATABASE_URL=postgresql+asyncpg://storico:storico@localhost:5432/storico

## CORS origins — comma-separated list of allowed origins
STORICO_AUTH_ALLOWED_ORIGINS=http://localhost:4321

## JWT secret — MUST match AUTH_SECRET below (used to verify proxy-generated JWTs)
# STORICO_AUTH_JWT_SECRET=

## ── Frontend (Astro — no prefix) ─────────────────────────────────

## Backend URL — used by Astro API proxy and Auth.js JWT callback
API_URL=http://127.0.0.1:8000

## Auth.js secret — generate with `openssl rand -base64 32`
## IMPORTANT: STORICO_AUTH_JWT_SECRET and AUTH_SECRET MUST be the same value.
# AUTH_SECRET=

## ── Auth.js OAuth providers ──────────────────────────────────────
## Google: https://console.cloud.google.com
## GitHub: https://github.com/settings/developers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

## OAuth callback URL — only needed behind a reverse proxy (ngrok, tunnel, etc.)
## Otherwise auto-detected from the request Host header.
# AUTH_URL=
