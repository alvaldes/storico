# ── Storico Environment Variables ──────────────────────────────────
#
# Copy this file to `.env` (same directory) and fill in the values.
# THIS IS THE SINGLE SOURCE OF TRUTH — both backend/ and frontend/ read
# from this file via symlinks (backend/.env -> ../.env, frontend/.env -> ../.env).
#
# Backend vars use prefix STORICO_ (pydantic-settings requirement).
# Frontend / Auth.js vars do NOT use the prefix.

## ── Backend (FastAPI — Python, prefix STORICO_) ───────────────────

## PostgreSQL — uses asyncpg driver for async support.
## Supabase (session pooler, IPv4):  postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
## Supabase (direct, IPv6 only):     postgresql+asyncpg://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
## Local dev:                        postgresql+asyncpg://storico:storico@localhost:5432/storico
STORICO_DATABASE_URL=postgresql+asyncpg://storico:storico@localhost:5432/storico

STORICO_QDRANT_URL=http://localhost:6333
STORICO_REDIS_URL=redis://localhost:6379/0
STORICO_OLLAMA_BASE_URL=http://localhost:11434
STORICO_CORS_ORIGINS=http://localhost:4321
STORICO_AUTH_ALLOWED_ORIGINS=http://localhost:4321
STORICO_HOST=127.0.0.1
STORICO_PORT=8000

## JWT secret — MUST match AUTH_SECRET below (used to verify proxy-generated JWTs)
# STORICO_AUTH_JWT_SECRET=

## ── Frontend (Astro — exposed to client, prefix PUBLIC_) ──────────

PUBLIC_API_URL=http://127.0.0.1:8000

## ── Auth.js OAuth — set up apps at:
##     https://console.cloud.google.com  (Google)
##     https://github.com/settings/developers  (GitHub)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

## Auth.js secret — generate with `openssl rand -base64 32`
## IMPORTANT: STORICO_AUTH_JWT_SECRET and AUTH_SECRET MUST be the same value.
# AUTH_SECRET=

## OAuth callback URL — only needed behind a reverse proxy (ngrok, tunnel, etc.)
## Otherwise auto-detected from the request Host header by auth-astro.
## Example: AUTH_URL=https://xxxx-xxx-xxx-xxx.ngrok-free.app
# AUTH_URL=

## Backend URL (used by Auth.js jwt callback to sync users)
API_URL=http://127.0.0.1:8000
