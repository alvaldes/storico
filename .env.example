# ── Storico Environment Variables ──────────────────────────────────

## Backend (FastAPI — Python, prefix STORICO_)
STORICO_DATABASE_URL=postgresql+asyncpg://storico:storico@localhost:5432/storico
STORICO_QDRANT_URL=http://localhost:6333
STORICO_REDIS_URL=redis://localhost:6379/0
STORICO_OLLAMA_BASE_URL=http://localhost:11434
STORICO_CORS_ORIGINS=http://localhost:4321
STORICO_AUTH_INTERNAL_TOKEN=change-this-to-a-random-uuid
STORICO_AUTH_ALLOWED_ORIGINS=http://localhost:4321
STORICO_HOST=127.0.0.1
STORICO_PORT=8000

## Frontend (Astro — exposed to client, prefix PUBLIC_)
PUBLIC_API_URL=http://127.0.0.1:8000

## Auth.js OAuth — set up apps at https://console.cloud.google.com and https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

## Shared secret between Astro proxy and FastAPI backend
STORICO_AUTH_INTERNAL_TOKEN=dev-insecure-token-change-in-production

## Backend URL (used by Auth.js jwt callback to sync users)
API_URL=http://127.0.0.1:8000
