# ── Storico Frontend Environment Variables ────────────────────────
# Copy this file to .env and fill in the values for local development.
# For Vercel production: set all vars in Vercel Project Dashboard → Settings → Environment Variables.

## When behind a reverse proxy like ngrok, set this to the full public HTTPS
## URL so Auth.js builds correct callback URLs (otherwise it uses http://
## from the local proxy). Example for ngrok:
# AUTH_URL=https://xxxx-xxx-xxx-xxx.ngrok-free.app
## In production on Vercel, AUTH_URL is auto-detected (VERCEL_URL) — only set this
## if Auth.js callback URLs are wrong.

## Backend API URL (server-side, used by Astro API proxy and Auth.js)
## Local dev: http://127.0.0.1:8000
## Production (Vercel): https://storico-api.vercel.app (or your custom domain)
API_URL=http://127.0.0.1:8000

## Shared secret between Astro proxy and FastAPI backend
## Must match STORICO_AUTH_INTERNAL_TOKEN in backend .env (local) or Vercel env (prod)
STORICO_AUTH_INTERNAL_TOKEN=

## Auth.js secret — generate with `openssl rand -base64 32`
AUTH_SECRET=

## Auth.js OAuth providers (optional — add at least one for login to work)
## GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
## Google: https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
