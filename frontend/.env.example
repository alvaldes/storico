# ── Storico Frontend Environment Variables ────────────────────────
#
# REFERENCE DOCUMENT — do NOT copy this file.
#
# The frontend reads from the repo-root `.env` via the symlink
#   frontend/.env -> ../.env    (already exists, don't recreate)
#
# For Vercel production: set all vars in
#   Vercel Project Dashboard → Settings → Environment Variables.

## Backend API URL (server-side, used by Astro API proxy and Auth.js)
## Local dev: http://127.0.0.1:8000
## Production: https://storico-api.vercel.app (your backend URL)
API_URL=http://127.0.0.1:8000

## Auth.js secret — used both for Auth.js JWT encryption AND for signing proxy JWTs
## that the backend verifies. MUST match STORICO_AUTH_JWT_SECRET in backend.
## Generate with: openssl rand -base64 32
AUTH_SECRET=

## Auth.js OAuth providers (optional — add at least one for login to work)
## GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
## Google: https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

## OAuth callback URL — only needed behind a reverse proxy (ngrok, tunnel, etc.)
## Otherwise auto-detected from request Host header (or VERCEL_URL on Vercel).
# AUTH_URL=
