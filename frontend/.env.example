# ── Storico Frontend Environment Variables ────────────────────────
# Copy this file to .env and fill in the values.
# All variables in this file are required unless noted as optional.

## Auth.js base URL — MUST be http://localhost:4321 for local dev.
## Google OAuth blocks callbacks from private IPs (192.168.x.x).
## If you change the port, update this accordingly.
AUTH_URL=http://localhost:4321

## Backend API URL (server-side, used by Astro API proxy and Auth.js)
API_URL=http://127.0.0.1:8000

## Backend API URL (client-side, exposed to browser — optional, for future use)
# Not currently used by the app, but available for client-side API calls.
# PUBLIC_API_URL=http://127.0.0.1:8000

## Shared secret between Astro proxy and FastAPI backend
## Must match STORICO_AUTH_INTERNAL_TOKEN in backend .env
STORICO_AUTH_INTERNAL_TOKEN=

## Auth.js secret — generate with `openssl rand -base64 32`
AUTH_SECRET=

## Auth.js OAuth providers (optional — add at least one for login to work)
## GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
## Google: https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
