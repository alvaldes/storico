{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "openpencil": {
      "type": "local",
      "command": [
        "node",
        "/Applications/OpenPencil.app/Contents/Resources/mcp-server.cjs",
        "--stdio"
      ],
      "enabled": true
    },
    "figma": {
      "type": "local",
      "command": ["npx", "-y", "figma-developer-mcp", "--stdio"],
      "environment": {
        "FIGMA_API_KEY": "${FIGMA_API_KEY}"
      },
      "enabled": true,
      "timeout": 15000
    }
  }
}
