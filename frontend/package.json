{
  "name": "storico-frontend",
  "type": "module",
  "version": "0.2.0",
  "private": true,
  "description": "Storico — LLM-powered user story to Kanban task extraction tool",
  "scripts": {
    "dev": "NODE_OPTIONS=\"--dns-result-order=ipv4first\" astro dev",
    "dev:debug": "NODE_OPTIONS=\"--dns-result-order=ipv4first\" astro dev --host --verbose",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.3",
    "@astrojs/vercel": "^9.0.5",
    "@auth/core": "^0.37.4",
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "astro": "^5.7.10",
    "auth-astro": "^4.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.510.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.2.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.18",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.1.6",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
