---
import { ClientRouter } from 'astro:transitions';
import '@/styles/globals.css';
import ThemeScript from '@/components/astro/ThemeScript.astro';
import { useTranslations } from '@/i18n/utils';

const { locale = 'en' } = Astro.props;
const t = useTranslations(locale);
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <ThemeScript />

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#2563eb" />
    <meta name="description" content={`${t.app.name} — ${t.app.tagline}`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
    <slot name="head" />
    <title>{t.app.name}</title>
  </head>
  <body class="flex min-h-dvh items-center justify-center bg-(--color-surface-secondary) p-4">
    <main class="w-full max-w-md">
      <div class="rounded-xl border border-(--color-border) bg-(--color-surface) p-8 shadow-sm">
        <slot />
      </div>
    </main>
  </body>
</html>
