---
import { ViewTransitions } from 'astro:transitions';
import '@/styles/globals.css';

const { locale = 'en' } = Astro.props;
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <!-- Anti-flash: apply theme before first paint -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var theme = stored || 'system';
        if (theme === 'system') {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light';
        }
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#2563eb" />
    <meta name="description" content="Storico — From user stories to Kanban tasks, automatically." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ViewTransitions />
    <slot name="head" />
    <title>Storico</title>
  </head>
  <body class="flex min-h-dvh items-center justify-center bg-(--color-surface-secondary) p-4">
    <!-- View Transitions: preserve theme across navigations -->
    <script>
      (function () {
        'use strict';
        var KEY = 'theme';
        function resolve() {
          var s = localStorage.getItem(KEY);
          if (s === 'dark' || s === 'light') return s;
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.addEventListener('astro:before-swap', function (e) {
          e.newDocument.documentElement.dataset.theme = resolve();
        });
      })();
    </script>
    <main class="w-full max-w-md">
      <div class="rounded-xl border border-(--color-border) bg-(--color-surface) p-8 shadow-sm">
        <slot />
      </div>
    </main>
  </body>
</html>
