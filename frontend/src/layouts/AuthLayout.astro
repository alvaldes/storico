---
import { ViewTransitions } from 'astro:transitions';
import '@/styles/globals.css';
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#2563eb" />
    <meta name="description" content="Storico — From user stories to Kanban tasks, automatically." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ViewTransitions />
    <slot name="head" />
    <title>Storico</title>
  </head>
  <body class="flex min-h-dvh items-center justify-center bg-(--color-surface-secondary) p-4">
    <main class="w-full max-w-md">
      <div class="rounded-xl border border-(--color-border) bg-(--color-surface) p-8 shadow-sm">
        <slot />
      </div>
    </main>
  </body>
</html>
