---
import { ClientRouter } from 'astro:transitions';
import '@/styles/globals.css';
import ThemeScript from '@/components/astro/ThemeScript.astro';
import PublicNavbar from '@/components/astro/PublicNavbar.astro';
import PublicFooter from '@/components/astro/PublicFooter.astro';
import { ArrowLeft } from 'lucide-react';
import { useTranslations, localizedPath, type Locale } from '@/i18n/utils';
import { Separator } from '@/components/ui/separator';

import { getSession } from 'auth-astro/server';

export interface Props {
  locale: Locale;
  title: string;
  description?: string;
  /** Whether to show the CTA section between content and footer. Default: true */
  showCta?: boolean;
}

const { locale = 'en', title = 'Storico', description, showCta = true } = Astro.props;
const t = useTranslations(locale);
const L = (path: string) => localizedPath(path, locale);

const session = await getSession(Astro.request);
const isLoggedIn = !!session?.user;

// Preserve current page on language switch
const cleanPath = Astro.url.pathname.replace(/^\/(en|es)/, '') || '/';
const currentPath = Astro.url.pathname;
const otherLocale: 'en' | 'es' = locale === 'en' ? 'es' : 'en';
const langToggleHref = localizedPath(cleanPath, otherLocale);

const navLinks = [
  { href: L('/docs'), label: t.footer.documentation },
  { href: L('/api'), label: t.footer.api_reference },
  { href: L('/status'), label: t.footer.status_page },
  { href: L('/about'), label: t.footer.about },
];
const ctaLink = { href: L(isLoggedIn ? '/dashboard' : '/login'), label: isLoggedIn ? t.nav.dashboard : t.landing.hero.cta_primary };
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <ThemeScript />

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#2563eb" />
    <meta
      name="description"
      content={description || t.app.tagline}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@700;800&family=Geist+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      .bg-landing-grid {
        background-image:
          linear-gradient(to right, color-mix(in oklch, var(--color-primary-400) 8%, transparent) 1px, transparent 1px),
          linear-gradient(to bottom, color-mix(in oklch, var(--color-primary-400) 8%, transparent) 1px, transparent 1px);
        background-size: 14px 24px;
      }

      .bg-cta-grid {
        background-image:
          linear-gradient(to right, color-mix(in oklch, var(--color-inverse-text) 8%, transparent) 1px, transparent 1px),
          linear-gradient(to bottom, color-mix(in oklch, var(--color-inverse-text) 8%, transparent) 1px, transparent 1px);
        background-size: 14px 24px;
        mask-image: radial-gradient(ellipse 60% 50% at 50% 0%, oklch(0 0 0) 70%, transparent 100%);
        -webkit-mask-image: radial-gradient(ellipse 60% 50% at 50% 0%, oklch(0 0 0) 70%, transparent 100%);
      }
    </style>
  </head>
  <body class="relative z-0 overflow-x-hidden bg-(--color-body) text-(--color-text) antialiased transition-colors duration-200">
    <!-- Background texture -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0 bg-landing-grid opacity-[0.4] dark:opacity-[0.1]" />
      <div class="absolute -top-48 -right-48 h-[600px] w-[600px] rounded-full bg-(--color-primary-400) opacity-[0.06] blur-[120px] dark:opacity-[0.04]" />
      <div class="absolute -bottom-32 -left-32 h-[400px] w-[400px] rounded-full bg-(--color-secondary-500) opacity-[0.04] blur-[100px] dark:opacity-[0.03]" />
    </div>

    <PublicNavbar
      locale={locale}
      currentPath={currentPath}
      langToggleHref={langToggleHref}
      navLinks={navLinks}
      ctaLink={ctaLink}
      isLoggedIn={isLoggedIn}
    />

    <!-- ════════════════════════════════════════════ -->
    <!-- PAGE CONTENT                                -->
    <!-- ════════════════════════════════════════════ -->
    {
      // Show "← Back to home" on every public page except the home page itself
      !currentPath.match(/^\/(en|es)?\/?$/) && (
        <div class="mx-auto max-w-3xl px-4 pt-12 md:px-8 lg:px-0 lg:pt-20">
          <div class="w-fit">
            <a
              href={L('/')}
              class="group inline-flex items-center gap-1.5 text-xs font-medium uppercase tracking-wider text-(--color-text-secondary) no-underline transition-all hover:text-(--color-primary-600)"
            >
              <ArrowLeft className="h-3 w-3 transition-transform group-hover:-translate-x-0.5" />
              {t.nav.back_to_home}
            </a>
            <Separator/>
          </div>
        </div>
      )
    }

    <slot />

    <!-- ════════════════════════════════════════════ -->
    <!-- CTA + FOOTER WRAPPER                        -->
    <!-- ════════════════════════════════════════════ -->
    <div class="relative overflow-hidden bg-(--color-inverse) dark:bg-transparent">
      <div class="absolute inset-0 bg-cta-grid pointer-events-none" />
      <img src="/favicon.svg" alt="" class="pointer-events-none absolute left-1/2 top-0 h-full w-auto -translate-x-1/2 opacity-[0.18] blur-[20px]" />

      {
        showCta && (
          <section>
            <div class="relative mx-auto flex max-w-7xl flex-col items-center justify-center gap-6 px-4 py-12 md:px-8 md:pt-10 md:pb-4 lg:px-20 lg:pt-12 lg:pb-10">
              <h2
                class="max-w-2xl text-center text-2xl font-extrabold leading-tight tracking-[-0.5px] text-(--color-inverse-text) md:text-3xl lg:text-[38px] lg:tracking-[-1px]"
                style="font-family: 'Space Grotesk', sans-serif;"
              >
                {t.landing.cta.title}
              </h2>
              <p class="max-w-xl text-center text-sm leading-[1.6] text-(--color-inverse-muted) md:text-base lg:text-lg">
                {t.landing.cta.subtitle}
              </p>
              <a
                href={L(isLoggedIn ? '/dashboard' : '/login')}
                class="inline-flex items-center rounded-lg bg-(--color-primary-600) px-8 py-3.5 text-sm font-semibold text-(--color-inverse-text) no-underline shadow-primary-lg transition-all hover:bg-(--color-primary-700) md:text-base"
              >
                {isLoggedIn ? t.nav.dashboard : t.landing.cta.button}
              </a>
            </div>
          </section>
        )
      }

      <PublicFooter locale={locale} langToggleHref={langToggleHref} />
    </div>

  <script>
  // Scroll to top on every navigation (theme is handled by ThemeScript)
  document.addEventListener('astro:after-swap', function () {
    window.scrollTo(0, 0);
  });

  // Update active nav link after client-side View Transitions
  function updatePublicNav() {
    const path = window.location.pathname.replace(/\/$/, '');
    document.querySelectorAll('[data-nav="public"] [data-nav-link]').forEach(function (a) {
      const href = a.getAttribute('href')?.replace(/\/$/, '');
      const match = href === path;
      a.classList.toggle('text-(--color-text)', match);
      a.classList.toggle('font-semibold', match);
      a.classList.toggle('text-(--color-text-secondary)', !match);
    });
  }

  document.addEventListener('astro:after-swap', updatePublicNav);
  document.addEventListener('DOMContentLoaded', updatePublicNav);
  </script>
  </body>
</html>
