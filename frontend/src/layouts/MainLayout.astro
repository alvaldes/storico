---
import { ClientRouter } from 'astro:transitions';
import '@/styles/globals.css';
import ThemeScript from '@/components/astro/ThemeScript.astro';
import Header from '@/components/astro/Header.astro';
import Sidebar from '@/components/astro/Sidebar.astro';
import { Toaster } from '@/components/ui/sonner';
import { getSession } from 'auth-astro/server';
import { useTranslations } from '@/i18n/utils';

const { locale = 'en' } = Astro.props;
const t = useTranslations(locale);
const currentPath = Astro.url.pathname;
const session = await getSession(Astro.request);
const userJson = JSON.stringify(session?.user ?? null);
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <ThemeScript />

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#2563eb" />
    <meta name="description" content={`${t.app.name} — ${t.app.tagline}`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
    <slot name="head" />
    <title>{t.app.name}</title>
  </head>
  <body class="min-h-dvh bg-(--color-surface)">
    <Sidebar locale={locale} currentPath={currentPath} />

    <div class="lg:pl-60 sidebar-collapsed:lg:pl-16 transition-[padding] duration-200">
      <Header locale={locale} userJson={userJson} />

      <main class="p-4 lg:p-6">
        <slot />
      </main>
    </div>

    <Toaster client:only="react" />
  </body>
</html>
