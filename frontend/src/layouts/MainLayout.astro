---
import { ClientRouter } from 'astro:transitions';
import ThemeScript from '@/components/astro/ThemeScript.astro';
import globalsCss from '@/styles/globals.css?url';
// Import sonner's CSS as a URL (Vite copies it to the output). The <link>
// gets data-astro-transition-persist so View Transitions never strips it.
import sonnerCss from 'sonner/dist/styles.css?url';
import { DashboardShell } from '@/components/react/DashboardShell';
import { getSession } from 'auth-astro/server';
import { useTranslations } from '@/i18n/utils';

const { locale = 'en' } = Astro.props;
const t = useTranslations(locale);
const currentPath = Astro.url.pathname;
const session = await getSession(Astro.request);
const userJson = JSON.stringify(session?.user ?? null);

// Read sidebar state cookie to avoid SSR hydration flash
const cookies = Astro.request.headers.get('cookie') ?? '';
const sidebarCookie = cookies
  .split(';')
  .find(c => c.trim().startsWith('sidebar_state='))
  ?.split('=')[1]
  ?.trim();
const sidebarDefaultOpen = sidebarCookie !== 'false';
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <ThemeScript />

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#2563eb" />
    <meta name="description" content={`${t.app.name} — ${t.app.tagline}`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="stylesheet" href={globalsCss} />
    <link rel="stylesheet" href={sonnerCss} data-astro-transition-persist />
    <ClientRouter />
    <slot name="head" />
    <title>{t.app.name}</title>
  </head>
  <body class="min-h-dvh bg-(--color-surface)">
    <DashboardShell
      client:load
      locale={locale}
      currentPath={currentPath}
      userJson={userJson}
      sidebarDefaultOpen={sidebarDefaultOpen}
    >
      <slot />
    </DashboardShell>

    <script>
    // Language toggle: replace history entry instead of pushing a new one
    document.addEventListener('click', async function onLangToggle(e) {
      const target = e.target as Element | null;
      const link = target?.closest('a[data-lang-toggle]');
      if (!link) return;
      e.preventDefault();
      const { navigate } = await import('astro:transitions/client');
      navigate((link as HTMLAnchorElement).href, { history: 'replace' });
    });
    </script>
  </body>
</html>
