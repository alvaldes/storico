---
import { ViewTransitions } from 'astro:transitions';
import '@/styles/globals.css';
import en from '@/i18n/en.json';
import es from '@/i18n/es.json';

const lang = Astro.currentLocale || 'en';
const t: any = lang === 'es' ? es : en;
const localePath = lang === 'es' ? '/es' : '';
---

<!DOCTYPE html>
<html lang={lang} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#2563eb" />
    <meta name="description" content={en.app.tagline} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ViewTransitions />
    <title>{t.app.name} — {t.app.tagline}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="overflow-x-hidden bg-[#F8FAFC] text-[#0F172A] antialiased">
    <!-- ════════════════════════════════════════════ -->
    <!-- NAVBAR                                      -->
    <!-- ════════════════════════════════════════════ -->
    <header class="border-b border-[#E2E8F0]">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 md:px-8 lg:px-20 lg:py-5">
      <a href={localePath || '/'} class="text-xl font-extrabold text-[#2563EB] no-underline md:text-[22px]">
        {t.app.name}
      </a>

      <!-- Mobile hamburger -->
      <button id="nav-toggle" class="flex items-center p-2 text-[#475569] lg:hidden" aria-label="Toggle menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>

      <!-- CTA mobile (visible siempre) + Desktop nav -->
      <div id="nav-menu" class="hidden lg:flex lg:items-center lg:gap-8">
        <nav class="flex flex-col gap-3 lg:flex-row lg:items-center lg:gap-8">
          <a
            href={`${localePath}/login`}
            class="text-[15px] font-medium text-[#475569] no-underline transition-colors hover:text-[#0F172A]"
          >
            {t.nav.dashboard}
          </a>
          <a
            href={`${localePath}/login`}
            class="text-[15px] font-medium text-[#475569] no-underline transition-colors hover:text-[#0F172A]"
          >
            {t.nav.stories}
          </a>
          <a
            href={`${localePath}/login`}
            class="text-[15px] font-medium text-[#475569] no-underline transition-colors hover:text-[#0F172A]"
          >
            {t.nav.kanban}
          </a>
          <a
            href={`${localePath}/login`}
            class="text-[15px] font-medium text-[#475569] no-underline transition-colors hover:text-[#0F172A]"
          >
            {t.nav.export}
          </a>
        </nav>

        <a
          href={`${localePath}/login`}
          class="inline-flex items-center rounded-lg bg-[#2563EB] px-5 py-2.5 text-sm font-semibold text-white no-underline transition-all hover:bg-[#1D4ED8]"
        >
          {t.landing.hero.cta_primary}
        </a>
      </div>
      </div>
    </header>

    <!-- Mobile nav overlay -->
    <div id="nav-overlay" class="fixed inset-0 z-40 hidden bg-black/50" />
    <div
      id="nav-drawer"
      class="fixed inset-y-0 right-0 z-50 flex w-64 translate-x-full flex-col gap-6 border-l border-[#E2E8F0] bg-white p-6 shadow-xl transition-transform duration-200"
    >
      <div class="flex items-center justify-between">
        <span class="text-lg font-bold text-[#0F172A]">{t.app.name}</span>
        <button id="nav-close" class="p-1 text-[#475569]" aria-label="Close menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
      <nav class="flex flex-col gap-2">
        <a
          href={`${localePath}/login`}
          class="rounded-lg px-3 py-2.5 text-[15px] font-medium text-[#475569] no-underline transition-colors hover:bg-[#F1F5F9] hover:text-[#0F172A]"
        >
          {t.nav.dashboard}
        </a>
        <a
          href={`${localePath}/login`}
          class="rounded-lg px-3 py-2.5 text-[15px] font-medium text-[#475569] no-underline transition-colors hover:bg-[#F1F5F9] hover:text-[#0F172A]"
        >
          {t.nav.stories}
        </a>
        <a
          href={`${localePath}/login`}
          class="rounded-lg px-3 py-2.5 text-[15px] font-medium text-[#475569] no-underline transition-colors hover:bg-[#F1F5F9] hover:text-[#0F172A]"
        >
          {t.nav.kanban}
        </a>
        <a
          href={`${localePath}/login`}
          class="rounded-lg px-3 py-2.5 text-[15px] font-medium text-[#475569] no-underline transition-colors hover:bg-[#F1F5F9] hover:text-[#0F172A]"
        >
          {t.nav.export}
        </a>
      </nav>
      <div class="mt-2 border-t border-[#E2E8F0] pt-4">
        <a
          href={`${localePath}/login`}
          class="flex items-center justify-center rounded-lg bg-[#2563EB] px-5 py-3 text-sm font-semibold text-white no-underline transition-all hover:bg-[#1D4ED8]"
        >
          {t.landing.hero.cta_primary}
        </a>
      </div>
    </div>

    <div class="mx-auto max-w-7xl px-4 md:px-8 lg:px-20">
    <!-- ════════════════════════════════════════════ -->
    <!-- HERO                                         -->
    <!-- ════════════════════════════════════════════ -->
    <section class="flex flex-col justify-around items-center gap-16 py-16 lg:flex-row lg:py-[100px]">
      <!-- Left -->
      <div class="flex w-full max-w-[565px] flex-col gap-6">
        <!-- Badge -->
        <span
          class="inline-flex w-fit items-center rounded-full border border-[#DBEAFE] bg-[#EFF6FF] px-3 py-1.5 text-[11px] font-bold uppercase tracking-wider text-[#2563EB]"
        >
          {t.landing.hero.badge}
        </span>

        <h1
          class="text-[2rem] font-[800] leading-[1.15] tracking-[-1px] text-[#0F172A] md:text-[3rem] lg:text-[52px] lg:tracking-[-1.5px]"
          style="font-family: 'Space Grotesk', sans-serif;"
        >
          {t.landing.hero.title}
        </h1>

        <p class="text-base leading-[1.6] text-[#475569] md:text-lg">
          {t.landing.hero.subtitle}
        </p>

        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
          <a
            href={`${localePath}/login`}
            class="inline-flex items-center justify-center rounded-lg bg-[#2563EB] px-7 py-3.5 text-base font-semibold text-white no-underline shadow-[0_4px_12px_rgba(37,99,235,0.2)] transition-all hover:bg-[#1D4ED8]"
          >
            {t.landing.hero.cta_primary}
          </a>
          <a
            href={`${localePath}/login`}
            class="inline-flex items-center justify-center rounded-lg border border-[#E2E8F0] bg-white px-7 py-3.5 text-base font-semibold text-[#0F172A] no-underline transition-all hover:bg-[#F8FAFC]"
          >
            {t.landing.hero.cta_secondary}
          </a>
        </div>
      </div>

      <!-- Right: Phone Mockup -->
      <div
        class="flex h-[480px] w-[260px] shrink-0 flex-col overflow-hidden rounded-[28px] border-[3px] border-[#1E293B] bg-[#0F172A] shadow-2xl sm:h-[540px] sm:w-[290px] sm:rounded-[32px] sm:border-[4px] lg:h-[590px] lg:w-[310px] lg:rounded-[36px]"
        style="box-shadow: 0 24px 48px -8px rgba(15, 23, 42, 0.15);"
      >
        <!-- Status bar -->
        <div class="flex h-10 items-center justify-between px-5 sm:h-11 sm:px-6">
          <span class="text-[12px] font-semibold text-white sm:text-[13px]">9:41</span>
        </div>

        <!-- App header -->
        <div class="flex h-11 items-center justify-between bg-[#1E293B] px-4 sm:h-13 sm:px-5">
          <span class="text-sm font-bold text-white sm:text-base">{t.app.name}</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="white"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
          </svg>
        </div>

        <!-- App content -->
        <div class="flex flex-col gap-3 px-4 py-3 sm:gap-4 sm:px-5 sm:py-4">
          <span class="text-[11px] font-semibold uppercase tracking-wider text-[#94A3B8] sm:text-[12px]">
            User Story
          </span>

          <div class="flex h-12 items-center rounded-xl bg-[#1E293B] px-3 sm:h-14 sm:px-4">
            <span class="text-[12px] text-[#64748B] sm:text-[13px]">As a user, I want to...</span>
          </div>

          <button
            class="flex h-10 w-full items-center justify-center rounded-lg bg-[#2563EB] text-xs font-semibold text-white transition-colors hover:bg-[#1D4ED8] sm:h-11 sm:text-sm"
          >
            Extraer tareas
          </button>

          <span class="text-[11px] font-semibold uppercase tracking-wider text-[#94A3B8] sm:text-[12px]">
            Tareas generadas
          </span>

          <!-- Task 1 -->
          <div class="flex flex-col gap-2 rounded-lg border border-[#334155] bg-[#1E293B] p-2.5 sm:p-3">
            <span class="text-[12px] font-medium text-[#E2E8F0] sm:text-[13px]">1. Set up auth endpoint</span>
            <div class="flex gap-1.5">
              <span
                class="inline-flex items-center rounded-full bg-[#FEF3C7] px-2 py-0.5 text-[10px] font-medium text-[#92400E] sm:px-2.5 sm:py-1 sm:text-[11px]"
              >
                backend
              </span>
              <span
                class="inline-flex items-center rounded-full bg-[#DBEAFE] px-2 py-0.5 text-[10px] font-medium text-[#1E40AF] sm:px-2.5 sm:py-1 sm:text-[11px]"
              >
                api
              </span>
            </div>
          </div>

          <!-- Task 2 -->
          <div class="flex flex-col gap-2 rounded-lg border border-[#334155] bg-[#1E293B] p-2.5 sm:p-3">
            <span class="text-[12px] font-medium text-[#E2E8F0] sm:text-[13px]">2. Create login form UI</span>
            <div class="flex gap-1.5">
              <span
                class="inline-flex items-center rounded-full bg-[#DBEAFE] px-2 py-0.5 text-[10px] font-medium text-[#1E40AF] sm:px-2.5 sm:py-1 sm:text-[11px]"
              >
                frontend
              </span>
              <span
                class="inline-flex items-center rounded-full bg-[#E0F2FE] px-2 py-0.5 text-[10px] font-medium text-[#075985] sm:px-2.5 sm:py-1 sm:text-[11px]"
              >
                ui/ux
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>
</div>

    <!-- ════════════════════════════════════════════ -->
    <!-- FEATURES                                     -->
    <!-- ════════════════════════════════════════════ -->
    <div class="mx-auto max-w-7xl px-4 md:px-8 lg:px-20">
    <section class="flex flex-col items-center gap-10 py-12 md:gap-14 md:py-[50px]">
      <div class="flex max-w-2xl flex-col items-center gap-4">
        <h2
          class="text-center text-2xl font-extrabold tracking-[-0.5px] text-[#0F172A] md:text-4xl md:tracking-[-1px]"
          style="font-family: 'Space Grotesk', sans-serif;"
        >
          {t.landing.features.title}
        </h2>
        <p class="text-center text-sm text-[#475569] md:text-base">
          {t.landing.features.subtitle}
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3 lg:gap-8">
        <!-- Card 1 -->
        <div
          class="flex flex-col gap-5 rounded-2xl border border-[#E2E8F0] bg-white p-7 shadow-sm"
          style="box-shadow: 0 8px 30px -4px rgba(15, 23, 42, 0.04);"
        >
          <div class="flex h-13 w-13 items-center justify-center rounded-xl bg-[#EFF6FF]">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#2563EB"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-[#0F172A]">{t.landing.features.card_1_title}</h3>
          <p class="text-sm leading-[1.6] text-[#475569]">
            {t.landing.features.card_1_desc}
          </p>
        </div>

        <!-- Card 2 -->
        <div
          class="flex flex-col gap-5 rounded-2xl border border-[#E2E8F0] bg-white p-7 shadow-sm"
          style="box-shadow: 0 8px 30px -4px rgba(15, 23, 42, 0.04);"
        >
          <div class="flex h-13 w-13 items-center justify-center rounded-xl bg-[#F0FDF4]">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#16A34A"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect width="18" height="18" x="3" y="3" rx="2" />
              <path d="M3 9h18" />
              <path d="M9 21V9" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-[#0F172A]">{t.landing.features.card_2_title}</h3>
          <p class="text-sm leading-[1.6] text-[#475569]">
            {t.landing.features.card_2_desc}
          </p>
        </div>

        <!-- Card 3 -->
        <div
          class="flex flex-col gap-5 rounded-2xl border border-[#E2E8F0] bg-white p-7 shadow-sm"
          style="box-shadow: 0 8px 30px -4px rgba(15, 23, 42, 0.04);"
        >
          <div class="flex h-13 w-13 items-center justify-center rounded-xl bg-[#FFF7ED]">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#EA580C"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="18" cy="5" r="3" />
              <circle cx="6" cy="12" r="3" />
              <circle cx="18" cy="19" r="3" />
              <line x1="8.59" y1="13.51" x2="15.42" y2="17.49" />
              <line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-[#0F172A]">{t.landing.features.card_3_title}</h3>
          <p class="text-sm leading-[1.6] text-[#475569]">
            {t.landing.features.card_3_desc}
          </p>
        </div>
      </div>
    </section>
    </div>

    <!-- ════════════════════════════════════════════ -->
    <!-- CTA                                        -->
    <!-- ════════════════════════════════════════════ -->
    <section class="bg-[#0F172A]">
      <div class="mx-auto flex max-w-7xl flex-col items-center justify-center gap-6 px-4 py-16 md:px-8 md:py-20 lg:px-20 lg:py-[100px]">
        <h2
          class="max-w-2xl text-center text-2xl font-extrabold leading-tight tracking-[-0.5px] text-white md:text-3xl lg:text-[38px] lg:tracking-[-1px]"
          style="font-family: 'Space Grotesk', sans-serif;"
        >
          {t.landing.cta.title}
        </h2>
        <p class="max-w-xl text-center text-sm leading-[1.6] text-[#94A3B8] md:text-base lg:text-lg">
          {t.landing.cta.subtitle}
        </p>
        <a
          href={`${localePath}/login`}
          class="inline-flex items-center rounded-lg bg-[#2563EB] px-8 py-3.5 text-sm font-semibold text-white no-underline shadow-lg transition-all hover:bg-[#1D4ED8] md:text-base"
          style="box-shadow: 0 4px 20px rgba(37, 99, 235, 0.25);"
        >
          {t.landing.cta.button}
        </a>
      </div>
    </section>

    <!-- ════════════════════════════════════════════ -->
    <!-- FOOTER                                      -->
    <!-- ════════════════════════════════════════════ -->
    <footer class="bg-[#0F172A]">
      <div class="mx-auto flex max-w-7xl flex-col items-center gap-10 px-4 pb-8 pt-12 md:gap-12 md:px-8 md:pb-10 md:pt-16 lg:px-20 lg:pt-20">
      <div class="flex w-full flex-col gap-10 md:flex-row md:flex-wrap md:items-start md:justify-between md:gap-12 lg:flex-nowrap lg:gap-20">
        <!-- Brand -->
        <div class="flex w-full max-w-[313px] flex-col gap-3 md:w-auto">
          <span class="text-lg font-bold text-white">{t.app.name}</span>
          <p class="text-sm leading-[1.6] text-[#94A3B8]">
            {t.app.tagline}
          </p>
        </div>

        <!-- Product -->
        <div class="flex flex-col gap-3">
          <span class="text-sm font-semibold text-white">Product</span>
          <a href={`${localePath}/login`} class="text-sm text-[#94A3B8] no-underline transition-colors hover:text-white">
            {t.nav.dashboard}
          </a>
          <a href={`${localePath}/login`} class="text-sm text-[#94A3B8] no-underline transition-colors hover:text-white">
            {t.nav.stories}
          </a>
          <a href={`${localePath}/login`} class="text-sm text-[#94A3B8] no-underline transition-colors hover:text-white">
            {t.nav.kanban}
          </a>
        </div>

        <!-- Resources -->
        <div class="flex flex-col gap-3">
          <span class="text-sm font-semibold text-white">Resources</span>
          <a href="#" class="text-sm text-[#94A3B8] no-underline transition-colors hover:text-white">
            Documentation
          </a>
          <a href="#" class="text-sm text-[#94A3B8] no-underline transition-colors hover:text-white">
            API Reference
          </a>
          <a href="#" class="text-sm text-[#94A3B8] no-underline transition-colors hover:text-white">
            Status
          </a>
        </div>

        <!-- Company / Legal -->
        <div class="flex flex-col gap-3">
          <span class="text-sm font-semibold text-white">Company</span>
          <a href="#" class="text-sm text-[#94A3B8] no-underline transition-colors hover:text-white">
            About
          </a>
          <a href="#" class="text-sm text-[#94A3B8] no-underline transition-colors hover:text-white">
            Privacy
          </a>
          <a href="#" class="text-sm text-[#94A3B8] no-underline transition-colors hover:text-white">
            Terms
          </a>
        </div>
      </div>

      <!-- Separator -->
      <div class="h-px w-full bg-[#1E293B]" />

      <!-- Bottom -->
      <div class="flex w-full flex-col items-center gap-3 md:flex-row md:justify-between">
        <p class="text-sm text-[#64748B]">
          &copy; {new Date().getFullYear()} {t.app.name}. All rights reserved.
        </p>
        <a
          href={`${localePath === '/es' ? '/' : '/es'}`}
          class="text-sm text-[#94A3B8] no-underline transition-colors hover:text-white"
        >
          {localePath === '/es' ? 'English' : 'Español'}
        </a>
      </div>
      </div>
    </footer>
  <script>
    const toggle = document.getElementById('nav-toggle');
    const close = document.getElementById('nav-close');
    const drawer = document.getElementById('nav-drawer');
    const overlay = document.getElementById('nav-overlay');

    function openMenu() {
      drawer?.classList.remove('translate-x-full');
      overlay?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      drawer?.classList.add('translate-x-full');
      overlay?.classList.add('hidden');
      document.body.style.overflow = '';
    }

    toggle?.addEventListener('click', openMenu);
    close?.addEventListener('click', closeMenu);
    overlay?.addEventListener('click', closeMenu);
  </script>
  </body>
</html>
