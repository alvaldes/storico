---
import AuthLayout from '@/layouts/AuthLayout.astro';
import en from '@/i18n/en.json';
---

<AuthLayout>
  <div slot="head">
    <title>Storico — {en.app.tagline}</title>
  </div>

  <div class="flex flex-col items-center text-center">
    <!-- Logo -->
    <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-(--color-primary-500)">
      <span class="text-3xl font-bold text-white">S</span>
    </div>

    <h1 class="text-3xl font-bold text-(--color-text)">
      {en.landing.hero_title}
    </h1>

    <p class="mt-3 text-(--color-text-secondary) leading-relaxed max-w-sm">
      {en.landing.hero_subtitle}
    </p>

    <div class="mt-8 flex flex-col sm:flex-row gap-3 w-full">
      <a
        href="/dashboard"
        class="inline-flex items-center justify-center rounded-lg bg-(--color-primary-500) px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-(--color-primary-600)"
      >
        {en.landing.cta_start}
      </a>
      <a
        href="/login"
        class="inline-flex items-center justify-center rounded-lg border border-(--color-border) px-6 py-3 text-sm font-medium text-(--color-text) transition-colors hover:bg-(--color-surface-secondary)"
      >
        {en.landing.cta_learn}
      </a>
    </div>

    <!-- Feature highlights -->
    <div class="mt-12 grid gap-6 sm:grid-cols-3 text-left w-full">
      <div class="rounded-lg border border-(--color-border) p-4">
        <h3 class="font-semibold text-(--color-text) text-sm">LLM-Powered</h3>
        <p class="mt-1 text-sm text-(--color-text-secondary)">
          Extract tasks from user stories using local or cloud LLMs.
        </p>
      </div>
      <div class="rounded-lg border border-(--color-border) p-4">
        <h3 class="font-semibold text-(--color-text) text-sm">Kanban Ready</h3>
        <p class="mt-1 text-sm text-(--color-text-secondary)">
          Visualize and manage tasks on a structured Kanban board.
        </p>
      </div>
      <div class="rounded-lg border border-(--color-border) p-4">
        <h3 class="font-semibold text-(--color-text) text-sm">Export Anywhere</h3>
        <p class="mt-1 text-sm text-(--color-text-secondary)">
          Push tasks to Trello, Jira, or export as JSON/Markdown.
        </p>
      </div>
    </div>
  </div>
</AuthLayout>
