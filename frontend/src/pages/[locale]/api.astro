---
import PublicLayout from '@/layouts/PublicLayout.astro';
import { Separator } from '@/components/ui/separator';
import { useTranslations, type Locale } from '@/i18n/utils';
import { config } from '@/lib/config';

const locale = (Astro.params.locale as Locale) || 'en';
const t = useTranslations(locale);
---

<PublicLayout
  locale={locale}
  title={`${t.app.name} — ${t.pages.api.title}`}
  description={t.pages.api.description}
>
  <div class="mx-auto max-w-3xl px-4 py-4 md:px-8 lg:px-0 lg:py-8">
    <h1
      class="mb-8 text-3xl font-extrabold tracking-[-0.5px] text-(--color-text) md:text-4xl lg:text-5xl"
      style="font-family: 'Space Grotesk', sans-serif;"
    >
      {t.pages.api.title}
    </h1>

    <div class="space-y-6 text-base leading-[1.7] text-(--color-text-secondary) md:text-lg">
      <p class="text-xs text-(--color-text-tertiary) uppercase">
        {t.pages.api.last_updated}
      </p>
      <p class="text-lg font-medium text-(--color-text)">
        {t.pages.api.intro}
        <a href={`${config.apiUrl}/docs`} target="_blank" rel="noopener noreferrer"
           class="inline-link"
           aria-label="OpenAPI documentation (opens in new tab)">
          <code class="rounded bg-(--color-surface-secondary) px-1.5 py-0.5 text-sm font-mono text-(--color-text) underline decoration-dotted underline-offset-2 transition-colors hover:text-(--color-primary-600)">/docs</code>
        </a>
        {t.pages.api.intro_end}
      </p>
      <Separator/>

      <h2 class="text-xl font-bold text-(--color-text)">{t.pages.api.auth_title}</h2>
      <p>{t.pages.api.auth}</p>

      <h2 class="text-xl font-bold text-(--color-text)">{t.pages.api.endpoints_title}</h2>

      <div class="rounded-lg border border-(--color-border) divide-y divide-(--color-border)">
        <div class="p-4">
          <div class="flex items-center gap-3 mb-1">
            <span class="rounded bg-(--color-method-post-bg) px-2 py-0.5 text-xs font-bold text-(--color-method-post-text)">POST</span>
            <code class="text-sm font-mono text-(--color-text)">/api/v1/extract</code>
          </div>
          <p class="text-sm text-(--color-text-secondary)">{t.pages.api.endpoint_extract_desc}</p>
        </div>
        <div class="p-4">
          <div class="flex items-center gap-3 mb-1">
            <span class="rounded bg-(--color-method-post-bg) px-2 py-0.5 text-xs font-bold text-(--color-method-post-text)">POST</span>
            <code class="text-sm font-mono text-(--color-text)">/api/v1/batch</code>
          </div>
          <p class="text-sm text-(--color-text-secondary)">{t.pages.api.endpoint_batch_desc}</p>
        </div>
        <div class="p-4">
          <div class="flex items-center gap-3 mb-1">
            <span class="rounded bg-(--color-method-get-bg) px-2 py-0.5 text-xs font-bold text-(--color-method-get-text)">GET</span>
            <code class="text-sm font-mono text-(--color-text)">/api/v1/status/{'{id}'}</code>
          </div>
          <p class="text-sm text-(--color-text-secondary)">{t.pages.api.endpoint_status_desc}</p>
        </div>
      </div>

      <p class="pt-4">
        {t.pages.api.footer}
        <a href={`${config.apiUrl}/docs`} target="_blank" rel="noopener noreferrer"
           class="inline-link"
           aria-label="Swagger documentation (opens in new tab)">
          <code class="rounded bg-(--color-surface-secondary) px-1.5 py-0.5 text-sm font-mono text-(--color-text) underline decoration-dotted underline-offset-2 transition-colors hover:text-(--color-primary-600)">/docs</code>
        </a>
        {t.pages.api.footer_end}
      </p>
    </div>
  </div>
</PublicLayout>
