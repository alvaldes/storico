---
import PublicLayout from '@/layouts/PublicLayout.astro';
import { useTranslations } from '@/i18n/utils';

const locale = (Astro.params.locale as string) || 'en';
const t = useTranslations(locale);
---

<PublicLayout
  locale={locale}
  title={`${t.app.name} — ${t.pages.api.title}`}
  description={t.pages.api.description}
>
  <div class="mx-auto max-w-3xl px-4 py-16 md:px-8 lg:px-20 lg:py-24">
    <h1
      class="mb-8 text-3xl font-extrabold tracking-[-0.5px] text-(--color-text) md:text-4xl"
      style="font-family: 'Space Grotesk', sans-serif;"
    >
      {t.pages.api.title}
    </h1>

    <div class="space-y-5 text-base leading-[1.7] text-(--color-text-secondary) md:text-lg">
      <p class="text-lg font-medium text-(--color-text)">
        Storico provides a REST API powered by FastAPI. Below is a summary of the main
        endpoints. Full OpenAPI documentation is available at <code class="rounded bg-(--color-surface-secondary) px-1.5 py-0.5 text-sm font-mono text-(--color-text)">/docs</code> when the backend is running.
      </p>

      <h2 class="text-xl font-bold text-(--color-text)">Authentication</h2>
      <p>
        All API requests require authentication via OAuth session. The frontend proxy
        automatically attaches the session token to requests.
      </p>

      <h2 class="text-xl font-bold text-(--color-text)">Endpoints</h2>

      <div class="rounded-lg border border-(--color-border) divide-y divide-(--color-border)">
        <div class="p-4">
          <div class="flex items-center gap-3 mb-1">
            <span class="rounded bg-green-100 px-2 py-0.5 text-xs font-bold text-green-700 dark:bg-green-900 dark:text-green-300">POST</span>
            <code class="text-sm font-mono text-(--color-text)">/api/v1/extract</code>
          </div>
          <p class="text-sm text-(--color-text-secondary)">Extract tasks from a single user story.</p>
        </div>
        <div class="p-4">
          <div class="flex items-center gap-3 mb-1">
            <span class="rounded bg-green-100 px-2 py-0.5 text-xs font-bold text-green-700 dark:bg-green-900 dark:text-green-300">POST</span>
            <code class="text-sm font-mono text-(--color-text)">/api/v1/batch</code>
          </div>
          <p class="text-sm text-(--color-text-secondary)">Process multiple user stories asynchronously.</p>
        </div>
        <div class="p-4">
          <div class="flex items-center gap-3 mb-1">
            <span class="rounded bg-blue-100 px-2 py-0.5 text-xs font-bold text-blue-700 dark:bg-blue-900 dark:text-blue-300">GET</span>
            <code class="text-sm font-mono text-(--color-text)">/api/v1/status/{'{id}'}</code>
          </div>
          <p class="text-sm text-(--color-text-secondary)">Check the status of an async batch extraction.</p>
        </div>
      </div>

      <p class="pt-4">
        For detailed request/response schemas, start the backend and visit
        <code class="rounded bg-(--color-surface-secondary) px-1.5 py-0.5 text-sm font-mono text-(--color-text)">/docs</code>
        for interactive Swagger documentation.
      </p>
    </div>
  </div>
</PublicLayout>
