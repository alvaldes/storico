---
import MainLayout from '@/layouts/MainLayout.astro';
import { StoriesList } from '@/components/react/StoriesList';
import { useTranslations, type Locale } from '@/i18n/utils';

const locale = (Astro.params.locale as Locale) || 'en';
const t = useTranslations(locale);
---

<MainLayout locale={locale}>
  <div slot="head">
    <title>{t.app.name} — {t.stories.title}</title>
  </div>

  <div class="space-y-1 mb-6">
    <h1 class="text-2xl font-semibold text-foreground">{t.stories.title}</h1>
    <p class="text-sm text-muted-foreground">{t.stories.description}</p>
  </div>

  <StoriesList client:load locale={locale} />
</MainLayout>
