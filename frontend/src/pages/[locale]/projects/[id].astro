---
import MainLayout from '@/layouts/MainLayout.astro';
import { ProjectDetail } from '@/components/react/ProjectDetail';
import { useTranslations, type Locale } from '@/i18n/utils';
import { getSession } from 'auth-astro/server';

const locale = (Astro.params.locale as Locale) || 'en';
const t = useTranslations(locale);
const session = await getSession(Astro.request);
const userId = session?.user?.id ?? '';
const { id } = Astro.params;
---

<MainLayout locale={locale}>
  <div slot="head">
    <title>{t.app.name} — {t.nav.stories}</title>
  </div>

  <ProjectDetail client:load locale={locale} projectId={id!} userId={userId} />
</MainLayout>
