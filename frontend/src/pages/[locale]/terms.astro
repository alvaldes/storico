---
import PublicLayout from '@/layouts/PublicLayout.astro';
import { useTranslations } from '@/i18n/utils';

const locale = (Astro.params.locale as string) || 'en';
const t = useTranslations(locale);
---

<PublicLayout
  locale={locale}
  title={`${t.app.name} — ${t.pages.terms.title}`}
  description={t.pages.terms.description}
>
  <div class="mx-auto max-w-3xl px-4 py-16 md:px-8 lg:px-20 lg:py-24">
    <h1
      class="mb-8 text-3xl font-extrabold tracking-[-0.5px] text-(--color-text) md:text-4xl"
      style="font-family: 'Space Grotesk', sans-serif;"
    >
      {t.pages.terms.title}
    </h1>

    <div class="space-y-5 text-base leading-[1.7] text-(--color-text-secondary) md:text-lg">
      <p>
        By using Storico, you agree to these terms. If you do not agree, do not use the
        service.
      </p>

      <h2 class="text-xl font-bold text-(--color-text)">Use of service</h2>
      <p>
        Storico is provided "as is" without any warranty. You are responsible for reviewing
        and validating the generated tasks before using them in any production or
        mission-critical environment.
      </p>

      <h2 class="text-xl font-bold text-(--color-text)">Open source</h2>
      <p>
        Storico is released under the <strong class="text-(--color-text)">MIT License</strong>.
        You are free to use, modify, and distribute the software in accordance with the
        terms of that license.
      </p>

      <h2 class="text-xl font-bold text-(--color-text)">Limitation of liability</h2>
      <p>
        Storico and its contributors shall not be liable for any damages arising from the
        use or inability to use the software. This includes, but is not limited to,
        incorrect task decomposition, data loss, or project delays.
      </p>

      <h2 class="text-xl font-bold text-(--color-text)">Changes to terms</h2>
      <p>
        We reserve the right to update these terms at any time. Continued use of Storico
        after changes constitutes acceptance of the new terms.
      </p>
    </div>
  </div>
</PublicLayout>
