---
import PublicLayout from '@/layouts/PublicLayout.astro';
import { Separator } from '@/components/ui/separator';
import { useTranslations } from '@/i18n/utils';

const locale = (Astro.params.locale as string) || 'en';
const t = useTranslations(locale);
---

<PublicLayout
  locale={locale}
  title={`${t.app.name} — ${t.pages.docs.title}`}
  description={t.pages.docs.description}
>
  <div class="mx-auto max-w-3xl px-4 py-4 md:px-8 lg:px-0 lg:py-8">
    <h1
      class="mb-8 text-3xl font-extrabold tracking-[-0.5px] text-(--color-text) md:text-4xl lg:text-5xl"
      style="font-family: 'Space Grotesk', sans-serif;"
    >
      {t.pages.docs.title}
    </h1>

    <div class="space-y-6 text-base leading-[1.7] text-(--color-text-secondary) md:text-lg">
      <p class="text-lg font-medium text-(--color-text)">
        {t.pages.docs.welcome}
      </p>
      <Separator/>

      <h2 class="text-xl font-bold text-(--color-text)">{t.pages.docs.getting_started_title}</h2>
      <ol class="list-decimal pl-6 space-y-2">
        <li><strong class="text-(--color-text)">{t.pages.docs.step_1}</strong></li>
        <li><strong class="text-(--color-text)">{t.pages.docs.step_2}</strong></li>
        <li><strong class="text-(--color-text)">{t.pages.docs.step_3}</strong></li>
        <li><strong class="text-(--color-text)">{t.pages.docs.step_4}</strong></li>
        <li><strong class="text-(--color-text)">{t.pages.docs.step_5}</strong></li>
        <li><strong class="text-(--color-text)">{t.pages.docs.step_6}</strong></li>
      </ol>

      <h2 class="text-xl font-bold text-(--color-text)">{t.pages.docs.story_format_title}</h2>
      <p>{t.pages.docs.story_format_intro}</p>
      <div class="rounded-lg border border-(--color-border) bg-(--color-surface-secondary) p-4 font-mono text-sm">
        {t.pages.docs.story_format_example}
      </div>
      <p>
        {t.pages.docs.story_format_example_desc}
        <em>{t.pages.docs.story_format_example_text}</em>
      </p>

      <h2 class="text-xl font-bold text-(--color-text)">{t.pages.docs.llm_backends_title}</h2>
      <ul class="list-disc pl-6 space-y-1">
        <li><strong class="text-(--color-text)">{t.pages.docs.llm_backend_ollama}</strong></li>
        <li><strong class="text-(--color-text)">{t.pages.docs.llm_backend_openai}</strong></li>
        <li><strong class="text-(--color-text)">{t.pages.docs.llm_backend_anthropic}</strong></li>
      </ul>

      <p class="pt-4 text-(--color-text-secondary)">
        {t.pages.docs.more_coming}
      </p>
    </div>
  </div>
</PublicLayout>
