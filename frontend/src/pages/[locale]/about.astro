---
import PublicLayout from '@/layouts/PublicLayout.astro';
import { Separator } from '@/components/ui/separator';
import { useTranslations, type Locale } from '@/i18n/utils';

const locale = (Astro.params.locale as Locale) || 'en';
const t = useTranslations(locale);
---

<PublicLayout
  locale={locale}
  title={`${t.app.name} — ${t.pages.about.title}`}
  description={t.pages.about.description}
>
  <div class="mx-auto max-w-3xl px-4 py-4 md:px-8 lg:px-0 lg:py-8">
    <h1
      class="mb-8 text-3xl font-extrabold tracking-[-0.5px] text-(--color-text) md:text-4xl lg:text-5xl"
      style="font-family: 'Space Grotesk', sans-serif;"
    >
      {t.pages.about.title}
    </h1>

    <div class="space-y-6 text-base leading-[1.7] text-(--color-text-secondary) md:text-lg">
      <p>
        {t.pages.about.intro_p1}
        <strong class="text-(--color-text)">{t.pages.about.intro_utm}</strong>
        {t.pages.about.intro_p2}
      </p>
      <Separator/>

      <h2 class="text-xl font-bold text-(--color-text)">{t.pages.about.mission_title}</h2>
      <p>{t.pages.about.mission}</p>

      <h2 class="text-xl font-bold text-(--color-text)">{t.pages.about.problem_title}</h2>
      <p>{t.pages.about.problem}</p>

      <h2 class="text-xl font-bold text-(--color-text)">{t.pages.about.team_title}</h2>
      <p>
        {t.pages.about.team_p1}
        <strong class="text-(--color-text)">{t.pages.about.team_author}</strong>
        {t.pages.about.team_p2}
        <strong class="text-(--color-text)">{t.pages.about.team_advisor}</strong>
        {t.pages.about.team_p3}
        <strong class="text-(--color-text)">{t.pages.about.team_coadvisor}</strong>.
      </p>
    </div>
  </div>
</PublicLayout>
