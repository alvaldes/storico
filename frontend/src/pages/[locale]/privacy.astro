---
import PublicLayout from '@/layouts/PublicLayout.astro';
import { useTranslations } from '@/i18n/utils';

const locale = (Astro.params.locale as string) || 'en';
const t = useTranslations(locale);
---

<PublicLayout
  locale={locale}
  title={`${t.app.name} — ${t.pages.privacy.title}`}
  description={t.pages.privacy.description}
>
  <div class="mx-auto max-w-3xl px-4 py-16 md:px-8 lg:px-20 lg:py-24">
    <h1
      class="mb-8 text-3xl font-extrabold tracking-[-0.5px] text-(--color-text) md:text-4xl"
      style="font-family: 'Space Grotesk', sans-serif;"
    >
      {t.pages.privacy.title}
    </h1>

    <div class="space-y-5 text-base leading-[1.7] text-(--color-text-secondary) md:text-lg">
      <p>
        Your privacy matters. This policy outlines how Storico handles your data when you
        use the application.
      </p>

      <h2 class="text-xl font-bold text-(--color-text)">Data we collect</h2>
      <p>
        When you sign in via Google or GitHub OAuth, we receive your email address and
        display name. We do <strong>not</strong> store passwords — authentication is
        handled entirely by your OAuth provider.
      </p>
      <p>
        The user stories you submit are sent to the configured LLM (local or cloud) for
        task extraction. If you use a local model via Ollama, your data never leaves your
        machine. If you use a cloud provider (OpenAI, Anthropic), your data is processed
        according to their respective policies.
      </p>

      <h2 class="text-xl font-bold text-(--color-text)">How we use your data</h2>
      <ul class="list-disc pl-6 space-y-2">
        <li>To provide the task extraction service</li>
        <li>To improve extraction quality via anonymized usage patterns</li>
        <li>To send service-related communications (if applicable)</li>
      </ul>

      <h2 class="text-xl font-bold text-(--color-text)">Data retention</h2>
      <p>
        You retain full ownership of your data. Projects, stories, and tasks can be deleted
        at any time from within the application. We do not sell or share your personal
        information with third parties.
      </p>

      <h2 class="text-xl font-bold text-(--color-text)">Contact</h2>
      <p>
        For privacy-related inquiries, please open an issue on our GitHub repository.
      </p>
    </div>
  </div>
</PublicLayout>
