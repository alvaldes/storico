---
import PublicLayout from '@/layouts/PublicLayout.astro';
import { useTranslations } from '@/i18n/utils';

const locale = (Astro.params.locale as string) || 'en';
const t = useTranslations(locale);
---

<PublicLayout
  locale={locale}
  title={`${t.app.name} — ${t.pages.privacy.title}`}
  description={t.pages.privacy.description}
>
  <div class="mx-auto max-w-3xl px-4 py-16 md:px-8 lg:px-20 lg:py-24">
    <h1
      class="mb-8 text-3xl font-extrabold tracking-[-0.5px] text-(--color-text) md:text-4xl"
      style="font-family: 'Space Grotesk', sans-serif;"
    >
      {t.pages.privacy.title}
    </h1>

    <div class="space-y-5 text-base leading-[1.7] text-(--color-text-secondary) md:text-lg">
      <p>{t.pages.privacy.intro}</p>

      <h2 class="text-xl font-bold text-(--color-text)">{t.pages.privacy.collection_title}</h2>
      <p>
        {t.pages.privacy.collection_oauth}
        <strong>{t.pages.privacy.collection_oauth_strong}</strong>
        {t.pages.privacy.collection_oauth_end}
      </p>
      <p>{t.pages.privacy.collection_llm}</p>

      <h2 class="text-xl font-bold text-(--color-text)">{t.pages.privacy.usage_title}</h2>
      <ul class="list-disc pl-6 space-y-2">
        <li>{t.pages.privacy.usage_1}</li>
        <li>{t.pages.privacy.usage_2}</li>
        <li>{t.pages.privacy.usage_3}</li>
      </ul>

      <h2 class="text-xl font-bold text-(--color-text)">{t.pages.privacy.retention_title}</h2>
      <p>{t.pages.privacy.retention}</p>

      <h2 class="text-xl font-bold text-(--color-text)">{t.pages.privacy.contact_title}</h2>
      <p>{t.pages.privacy.contact}</p>
    </div>
  </div>
</PublicLayout>
