---
/**
 * ThemeScript — theme lifecycle manager for ALL layouts and pages.
 *
 * Provides:
 *  1. Anti-flash inline script (runs before first paint in <head>)
 *  2. View Transitions theme persistence
 *  3. System preference change detection
 *
 * Every layout (MainLayout, PublicLayout, AuthLayout) and standalone page
 * (index.astro) MUST include this component in their <head>.
 *
 * Theme interaction (toggling) is handled by the React <ThemeToggle />
 * component via Zustand, which writes to the same localStorage key.
 * This script reads from localStorage — both systems stay in sync
 * automatically.
 */
---

<!-- Anti-flash: runs before first paint to prevent FOUC -->
<script is:inline>
  (function () {
    var stored = localStorage.getItem('theme');
    var theme = stored || 'system';
    if (theme === 'system') {
      theme = window.matchMedia('(prefers-color-scheme: dark)').matches
        ? 'dark'
        : 'light';
    }
    document.documentElement.setAttribute('data-theme', theme);
  })();
</script>

<!-- Theme persistence across View Transitions + system preference changes -->
<script>
  import {
    resolveTheme,
    applyTheme,
    onBeforeSwap,
    onAfterSwap,
    onSystemPreferenceChange,
  } from '@/lib/theme';

  /* ── View Transitions ─────────────────────────── */
  document.addEventListener('astro:before-swap', onBeforeSwap);
  document.addEventListener('astro:after-swap', onAfterSwap);

  /* ── System preference changes ─────────────────── */
  window
    .matchMedia('(prefers-color-scheme: dark)')
    .addEventListener('change', onSystemPreferenceChange);

  /* ── Initialize current page ───────────────────── */
  applyTheme(resolveTheme());
</script>
