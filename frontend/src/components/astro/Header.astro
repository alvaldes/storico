---
import { ThemeToggle } from '../react/ThemeToggle';
import { UserMenu } from '../react/UserMenu';
import { Menu } from 'lucide-react';
import GitHubIcon from './GitHubIcon.astro';
import LangToggle from './LangToggle.astro';
import { useTranslations, localizedPath } from '@/i18n/utils';
import {
  Breadcrumb,
  BreadcrumbList,
  BreadcrumbItem,
  BreadcrumbLink,
  BreadcrumbPage,
  BreadcrumbSeparator,
} from '@/components/ui/breadcrumb';

const { locale = 'en', userJson } = Astro.props;
const t = useTranslations(locale);

// Preserve current page on language switch
const cleanPath = Astro.url.pathname.replace(/^\/(en|es)/, '') || '/';
const otherLocale = locale === 'en' ? 'es' : 'en';
const langToggleHref = localizedPath(cleanPath, otherLocale);

// ── Auto breadcrumb ─────────────────────────────────────────────
// Maps path segments to nav translation keys
const segmentLabelKey: Record<string, string> = {
  dashboard: 'dashboard',
  stories: 'stories',
  kanban: 'kanban',
  export: 'export',
  settings: 'settings',
};

// Split path into segments, ignoring empty strings
const segments = cleanPath.split('/').filter(Boolean);

// Build breadcrumb trail: [home, ...segments]
// Each item has label, href, and whether it's the last (current page)
type BreadcrumbItem = { label: string; href: string; isLast: boolean };
const trail: BreadcrumbItem[] = [
  { label: t.app.name, href: localizedPath('/', locale), isLast: segments.length === 0 },
  ...segments.map((seg, i) => {
    const key = segmentLabelKey[seg];
    return {
      label: key ? (t.nav as Record<string, string>)[key] : seg,
      href: localizedPath('/' + segments.slice(0, i + 1).join('/'), locale),
      isLast: i === segments.length - 1,
    };
  }),
];
---

<header
  class="flex h-14 items-center justify-between border-b border-(--color-border) bg-(--color-surface) px-4 lg:px-6"
>
  <div class="flex items-center gap-3">
    <button
      id="sidebar-toggle"
      class="rounded-md p-1.5 text-(--color-text-secondary) hover:bg-(--color-surface-secondary) transition-colors lg:hidden"
      aria-label={t.sidebar.expand}
      title={t.sidebar.expand}
    >
      <Menu className="h-5 w-5" />
    </button>

    <!-- Auto breadcrumb -->
    <Breadcrumb class="hidden sm:flex">
      <BreadcrumbList>
        {trail.map((item, i) => (
          <>
            {i > 0 && <BreadcrumbSeparator />}
            <BreadcrumbItem>
              {item.isLast ? (
                <BreadcrumbPage>{item.label}</BreadcrumbPage>
              ) : (
                <BreadcrumbLink href={item.href}>{item.label}</BreadcrumbLink>
              )}
            </BreadcrumbItem>
          </>
        ))}
      </BreadcrumbList>
    </Breadcrumb>
  </div>

  <div class="flex items-center gap-2">
    <UserMenu userJson={userJson} locale={locale} client:load />
    <LangToggle href={langToggleHref} locale={locale} />
    <ThemeToggle client:load />
    <a
      href="https://github.com/alvaldes/storico"
      target="_blank"
      rel="noopener noreferrer"
      class="rounded-md p-1.5 text-(--color-text-secondary) hover:text-(--color-text) hover:bg-(--color-surface-secondary) transition-colors"
      aria-label="GitHub repository"
      title="GitHub repository"
    >
      <GitHubIcon class="h-5 w-5" />
    </a>
  </div>
</header>

<script>
  const toggle = document.getElementById('sidebar-toggle');
  if (toggle) {
    toggle.addEventListener('click', () => {
      document.documentElement.classList.toggle('sidebar-open');
    });
  }
</script>
