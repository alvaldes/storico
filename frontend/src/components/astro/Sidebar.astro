---
import {
  LayoutDashboard,
  FileText,
  KanbanSquare,
  Upload,
  Settings,
  PanelLeftClose,
  PanelLeftOpen,
} from 'lucide-react';
import { localizedPath, useTranslations, type Locale } from '@/i18n/utils';
import pkg from '../../../package.json';

const { locale = 'en' as Locale, currentPath = '' } = Astro.props;
const t = useTranslations(locale);
const L = (path: string) => localizedPath(path, locale);

const nav = t.nav;
const navLinks = [
  { href: L('/dashboard'), icon: LayoutDashboard, label: nav['dashboard'] },
  { href: L('/stories'), icon: FileText, label: nav['stories'] },
  { href: L('/kanban'), icon: KanbanSquare, label: nav['kanban'] },
  { href: L('/export'), icon: Upload, label: nav['export'] },
  { href: L('/settings'), icon: Settings, label: nav['settings'] },
];

function isActive(href: string): boolean {
  return currentPath === href || currentPath.replace(/\/$/, '') === href.replace(/\/$/, '');
}
---

<aside
  id="sidebar"
  class="fixed left-0 z-40 flex w-60 sidebar-collapsed:w-16 flex-col bg-(--color-surface) transition-[width,transform] duration-200 -translate-x-full top-14 rounded-b-xl shadow-lg lg:inset-y-0 lg:top-0 lg:shadow-none lg:rounded-none lg:border-r lg:border-(--color-border) lg:translate-x-0 sidebar-open:translate-x-0"
  data-nav="sidebar"
>
  <!-- Logo — hidden on mobile (header has it), always visible on desktop -->
  <div
    class="hidden lg:flex h-14 items-center justify-between border-b border-(--color-border) px-4 sidebar-collapsed:justify-center sidebar-collapsed:px-0"
  >
    <a href={L('/')} class="inline-flex items-center gap-2.5 no-underline sidebar-collapsed:hidden">
      <img src="/favicon.svg" alt="" class="h-6 w-auto shrink-0" />
      <span class="text-lg font-bold text-(--color-text)">{t.app.name}</span>
    </a>
    <button
      id="sidebar-collapse-toggle"
      class="rounded-md p-1.5 text-(--color-text-secondary) hover:bg-(--color-surface-secondary) transition-colors"
      aria-label={t.sidebar.collapse}
      title={t.sidebar.collapse}
    >
      <PanelLeftClose className="h-5 w-5 sidebar-collapsed:hidden" />
      <PanelLeftOpen className="h-5 w-5 hidden sidebar-collapsed:block" />
    </button>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 overflow-y-auto p-3 space-y-1">
    {
      navLinks.map(({ href, icon: Icon, label }) => (
        <a
          href={href}
          data-nav-link
          title={label}
          class={`flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium transition-colors ${
            isActive(href)
              ? 'bg-(--color-surface-secondary) text-(--color-text) font-semibold'
              : 'text-(--color-text-secondary) hover:bg-(--color-surface-secondary) hover:text-(--color-text)'
          } sidebar-collapsed:justify-center sidebar-collapsed:px-0`}
        >
          <Icon className="h-4 w-4 shrink-0" />
          <span class="sidebar-collapsed:hidden">{label}</span>
        </a>
      ))
    }
  </nav>

  <!-- Footer -->
  <div class="border-t border-(--color-border) p-3">
    <p class="text-xs text-(--color-text-secondary) text-center truncate">
      <span class="sidebar-collapsed:hidden">{t.app.name} </span>
      v{pkg.version}
    </p>
  </div>
</aside>

<!-- Overlay for mobile -->
<div
  id="sidebar-overlay"
  class="fixed inset-0 z-30 bg-black/50 opacity-0 pointer-events-none transition-opacity duration-200 lg:hidden sidebar-open:opacity-100 sidebar-open:pointer-events-auto"
></div>

<script>
  const overlay = document.getElementById('sidebar-overlay');
  const sidebar = document.getElementById('sidebar');

  function closeSidebar() {
    document.documentElement.classList.remove('sidebar-open');
  }

  if (overlay) {
    overlay.addEventListener('click', closeSidebar);
  }

  // ── Close sidebar on nav link click (mobile) ──
  if (sidebar) {
    sidebar.addEventListener('click', (e) => {
      const link = e.target.closest('[data-nav-link]');
      if (link) closeSidebar();
    });
  }

  // ── Active nav link on View Transitions (client-side nav) ──
  function updateActiveNav() {
    const path = window.location.pathname.replace(/\/$/, '');
    document.querySelectorAll('[data-nav="sidebar"] [data-nav-link]').forEach((a) => {
      const href = a.getAttribute('href')?.replace(/\/$/, '');
      const match = href === path;
      a.classList.toggle('text-(--color-text)', match);
      a.classList.toggle('font-semibold', match);
      a.classList.toggle('bg-(--color-surface-secondary)', match);
      a.classList.toggle('text-(--color-text-secondary)', !match);
    });
  }

  document.addEventListener('astro:after-swap', updateActiveNav);

  // ── Desktop collapse toggle ──
  const collapseBtn = document.getElementById('sidebar-collapse-toggle');
  if (collapseBtn) {
    // Restore persisted state on load
    const saved = localStorage.getItem('sidebar-collapsed');
    if (saved === 'true') {
      document.documentElement.classList.add('sidebar-collapsed');
    }

    collapseBtn.addEventListener('click', () => {
      document.documentElement.classList.toggle('sidebar-collapsed');
      const isCollapsed = document.documentElement.classList.contains('sidebar-collapsed');
      localStorage.setItem('sidebar-collapsed', String(isCollapsed));
    });
  }
</script>
