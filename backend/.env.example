# Storico Backend — Environment Configuration

# --- Application ---
STORICO_APP_NAME=Storico API
STORICO_DEBUG=false

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://storico:storico@localhost:5432/storico

# --- Qdrant (Vector Store) ---
QDRANT_URL=http://localhost:6333

# --- Redis (Celery Broker) ---
REDIS_URL=redis://localhost:6379/0

# --- Ollama (Local LLM) ---
OLLAMA_BASE_URL=http://localhost:11434
