# Storico Backend — Reference: Environment Variables
#
# REFERENCE DOCUMENT — do NOT copy this file.
#
# The backend reads from the repo-root `.env` via the symlink
#   backend/.env -> ../.env    (already exists, don't recreate)
#
# Below is the COMPLETE LIST of all STORICO_ vars that pydantic-settings
# can load from the root `.env`. Only the ones you actually override need
# to be in `.env` — pydantic uses the defaults shown here for the rest.
#
# For the minimal working set, see ../.env.example (repo root).
# All backend vars use the `STORICO_` prefix (see src/storico/config/settings.py).
# Frontend / Auth.js vars do NOT use the prefix.

# --- Application ---
STORICO_APP_NAME=Storico API
STORICO_DEBUG=false

# --- PostgreSQL ---
# Local Docker (default). For Supabase dev, replace with:
# STORICO_DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.xxx.supabase.co:5432/postgres
STORICO_DATABASE_URL=postgresql+asyncpg://storico:storico@localhost:5432/storico

# --- Qdrant (Vector Store) ---
STORICO_QDRANT_URL=http://localhost:6333

# --- Redis (Celery Broker) ---
STORICO_REDIS_URL=redis://localhost:6379/0

# --- Ollama (Local LLM) ---
STORICO_OLLAMA_BASE_URL=http://localhost:11434
STORICO_OLLAMA_HOST=http://localhost:11434
STORICO_LLM_TIMEOUT=120

# --- Embedding ---
STORICO_EMBEDDING_MODEL=nomic-embed-text
STORICO_EMBEDDING_DIMENSIONS=768

# --- Vector store (Qdrant) ---
STORICO_QDRANT_COLLECTION=storico_extractions

# --- RAG ---
STORICO_RAG_SIMILARITY_THRESHOLD=0.85
STORICO_RAG_MAX_EXAMPLES=3

# --- CORS ---
STORICO_CORS_ORIGINS=http://localhost:4321

# --- Auth ---
STORICO_AUTH_INTERNAL_TOKEN=dev-insecure-token-change-in-production
STORICO_AUTH_JWT_SECRET=dev-insecure-token-change-in-production
STORICO_AUTH_ALLOWED_ORIGINS=http://localhost:4321

# --- Server ---
STORICO_HOST=127.0.0.1
STORICO_PORT=8000

## --- Auth.js secret (mutual) ---
# AUTH_SECRET must match STORICO_AUTH_JWT_SECRET — set in root .env
