# ── Storico Backend Environment Variables ─────────────────────────
#
# REFERENCE DOCUMENT — do NOT copy this file.
#
# The backend reads from the repo-root `.env` via the symlink
#   backend/.env -> ../.env    (already exists, don't recreate)
#
# All vars use the STORICO_ prefix and are loaded by pydantic-settings.
# Defaults are shown below — only override what differs from defaults.

# PostgreSQL (asyncpg)
# Local Docker: postgresql+asyncpg://storico:storico@localhost:5432/storico
# Neon:         postgresql+asyncpg://user:password@ep-xxx.aws.neon.tech/neondb?sslmode=require
# STORICO_DATABASE_URL=postgresql+asyncpg://storico:storico@localhost:5432/storico

# CORS — comma-separated allowed origins
# STORICO_AUTH_ALLOWED_ORIGINS=http://localhost:4321

# Auth — JWT secret (must match AUTH_SECRET from frontend .env)
# STORICO_AUTH_JWT_SECRET=dev-insecure-token-change-in-production
